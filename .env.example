# ================================
# CONFIGURACIÓN DEL SERVIDOR
# ================================
PORT=3000
NODE_ENV=development

# ================================
# BASE DE DATOS PostgreSQL
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cobros_db
DB_USER=postgres
DB_PASSWORD=postgres

# ================================
# JWT - Autenticación
# ================================
JWT_SECRET=cambia_esto_por_un_string_muy_largo_y_seguro_2024
JWT_EXPIRES_IN=7d

# ================================
# ARCHIVOS / IMÁGENES
# ================================
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ================================
# CORS - Origins permitidos
# ================================
# Desarrollo: frontend en local (Angular 4200, Vite 5173, etc.)
# Producción (Railway): pon la URL de tu frontend desplegado, NO localhost
# Ejemplo: https://cobros-app.vercel.app,https://tu-dominio.com
ALLOWED_ORIGINS=http://localhost:4200

# ================================
# RATE LIMIT (opcional)
# ================================
# RATE_LIMIT_API_MAX=100

# ================================
# WhatsApp (Twilio) - Alertas
# ================================
# Cuenta en https://www.twilio.com → Console para Account SID y Auth Token.
# WhatsApp Sandbox: https://www.twilio.com/docs/whatsapp/sandbox (From: whatsapp:+14155238886)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
